 {
   "_comment": "Multi-tier news source configuration. Tiers: rss (fast, structured), aggregator (medium, search-based), official (slow, JS-rendered risk). The fetcher tries tier 1 first, falls back through tiers on failure.",
   "global": {
     "per_source_timeout_seconds": 8,
     "max_total_time_seconds": 90,
     "retry_count": 1,
     "user_agent": "AI-Research-Daily/1.0 (research bot; contact via repo)"
   },
   "universal_fallbacks": [
     {
       "name": "Google News RSS",
       "type": "rss",
       "url_template": "https://news.google.com/rss/search?q={query}&hl=en-US&gl=US&ceid=US:en",
       "note": "Works for any keyword. Add &when:24h for last 24h if supported."
     }
   ],
